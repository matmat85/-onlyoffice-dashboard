# URL of the OnlyOffice Document Server (as seen by the browser)
ONLYOFFICE_URL=http://your-onlyoffice-host

# URL of this dashboard app (as seen by the OnlyOffice container)
APP_URL=http://your-dashboard-host:3000

# Port for the dashboard
PORT=3000

# JWT secret – must match services.CoAuthoring.secret.*.string in local.json
JWT_SECRET=your_jwt_secret_here

# Local auth (optional) — if set, creates a local admin user on startup
LOCAL_ADMIN_EMAIL=
LOCAL_ADMIN_PASSWORD=
LOCAL_ADMIN_NAME=Local Admin

# Optional: allow open local self-registration endpoint
ALLOW_LOCAL_REGISTRATION=false
